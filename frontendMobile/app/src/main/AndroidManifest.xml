<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools" >

    <uses-permission android:name="android.permission.INTERNET" />

    <application


        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EnterpriseMobile"
        android:usesCleartextTraffic="true" >

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.EnterpriseMobile" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>



        <activity android:name=".HomeViaggiatoreActivity" android:exported="false" />
        <activity android:name=".PrenotaViaggioActivity" android:exported="false" />
        <activity android:name=".MiePrenotazioniActivity" android:exported="false" />
        <activity android:name=".HomeOrganizzatoreActivity" android:exported="false" />
        <activity android:name=".PagamentoActivity" android:exported="false" />
        <activity android:name=".AmiciziaActivity" android:exported="false" />
        <activity android:name=".DettaglioViaggioActivity" android:exported="false" />
        <activity android:name=".CreaViaggioActivity" android:exported="false" />
        <activity android:name=".ProfiloActivity" android:exported="false" />

        <service
            android:name=".MioFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>
</manifest>